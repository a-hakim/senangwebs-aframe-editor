@import './lib';

#toolbar
  background-color $bgdark

  .toolbarActions
    padding 0
    height 48px
    display grid
    grid-template-columns repeat(2, minmax(0, 1fr))

    a.button
      display flex
      justify-content center
      align-items center
      flex-direction column
      margin 0

      svg
        color inherit

      span
        font-size 12px

    a.button:hover
      color $primary

    a.disabled
      color #666
      cursor default

#leftPanel
  display flex
  flex-direction column

.scenegraph-menubar
    display flex
    height 40px
    width 20rem
    justify-content space-between
    background-color $bg

#scenegraph
  background $bg
  border-top 1px solid #111
  display flex
  flex-direction column
  overflow auto
  width 20rem
  height calc(100vh - 40px)

  .entity
    background $bg
    cursor pointer
    display flex
    justify-content space-between
    padding 8px
    white-space nowrap
    transition background 0.2s, box-shadow 0.2s
    position relative

    // first <span> element child

    span:first-child
      max-width 260px
      overflow hidden

      i:first-child
        margin-right 8px

    &.drag-above .drop-indicator.drop-above
      position absolute
      left: 0
      right: 0
      top: 0
      height: 4px
      background white
      border-radius 2px
      z-index 2
      transition background 0.15s, opacity 0.15s
      opacity 1

    &.drag-below .drop-indicator.drop-below
      position: absolute
      left: 0
      right: 0
      bottom: 0
      height: 4px
      background: #00FF99
      border-radius: 2px
      z-index: 2
      transition: background 0.15s, opacity 0.15s
      opacity: 1

    &.drag-center .drop-indicator.drop-center
      position: absolute
      left: 4px
      right: 4px
      top: 25%
      height: 50%
      background: rgba(24,136,193,0.15)
      border-radius: 4px
      z-index: 1
      transition: background 0.15s, opacity 0.15s
      opacity: 1

    &:hover
      background #ffffff1a

    &.active
      background-color #ffffff1a
      border-top 2px solid #00FF99
      color #fff
      .component:hover
        color yellow
      .entityActions
        display flex

    &.novisible
      &.active
        span,
        svg,
        .collapsespace,
        .id
          color #999

      &:not(.active)
        span,
        svg,
        .collapsespace,
        .id
          color #626262

    &.drag-over
      background #ffffff1a !important
      color #fff !important
      box-shadow 0 0 0 0 #00FF99
      z-index 2
      transition background 0.2s, box-shadow 0.2s

  .drop-indicator
    height 4px
    background #ffffff1a
    border-radius 2px
    margin 0 4px
    opacity 0.85
    transition background 0.2s
    position relative
    z-index 3

  .component:hover
    color #09090B

  .entityIcons
    margin-left 2px

  .entityActions
    display flex
    gap 4px
    margin 0 4px

    .button
      color #fff
      font-size 12px
      margin-left 6px

  svg
    color #CCC

  .entityActions svg:hover
    color $primary

  .active svg
    color #FAFAFA

  .id
    color #ccc

  .option.active .id
    color #fff

  .collapsespace
    color #eee
    display inline-block
    text-align center
    width 14px
    margin-right 4px

  .fa-eye
    color #bbb

  .icons a.button
    color #fff

  .search
    padding 0px
    font-size 16px
    position relative
    overflow hidden

    input
      color $white
      background $bg
      border-radius 0px
      border-bottom 1px solid $bgdark
      height 40px
      text-indent 10px
      width 20rem

    svg
      position absolute
      right 12px
      top 12px

  .outliner
    background $bg
    color $white
    cursor default
    flex 1 1 auto
    font-size 14px
    line-height normal
    outline none
    overflow-y auto
    padding 0px
    width 20rem

.scenegraph-bottom
  background-color #323232
  border-top 1px solid #111
  bottom 10
  height 40px
  left 0
  z-index 100

  a
    float right
    margin 10px
